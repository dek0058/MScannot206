@Component
script DevMapComponent extends Component

	@HideFromInspector()
	property MinimapComponent minimapCom = nil

	@ExecSpace("Client")
	method void Setup()
		local screen = _GameClientUILogic.currentScreen

		---@type MinimapComponent
		local minimapCom = _GameplayStaticsLogic:FindComponentInParent(screen, "MinimapComponent")
		if minimapCom ~= nil then
			self.minimapCom = minimapCom
			self.minimapCom:Setup(self.Entity)
		end
	end

	@ExecSpace("Client")
	method void AddMinimapUserMarker(string uid)
		if self.minimapCom == nil then
			return
		end

		local user = _UserService.UserEntities[uid]
		if user ~= nil then
			self.minimapCom:AddUser(user)
		end
	end

	@ExecSpace("Client")
	method void RemoveMinimapUserMarker(string uid)
		if self.minimapCom == nil then
			return
		end

		self.minimapCom:RemoveUser(uid)
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleMapEnterEvent(MapEnterEvent e)
		_TransitionLogic:Pop(e.uid)

		local userLocalPlayerCom = _UserProxy:GetUserLocalPlayerComponentByServer(e.uid)
		if userLocalPlayerCom == nil then
			_GameServerLogic:KickByServer(e.uid, "로컬 플레이어를 찾을 수 없습니다.", "WorldError")
			return
		end
		
		local userCharacterCom = _UserProxy:GetUserCharacterComponentByServer(e.uid)
		if userCharacterCom == nil then
			_GameServerLogic:KickByServer(e.uid, "유저 캐릭터 컴포넌트를 찾을 수 없습니다.", "WorldError")
			return
		end
		
		userCharacterCom:Reset()
		userLocalPlayerCom:SetEnable(true)

		self:Setup(e.uid)

		for _, user in ipairs(_UserService:GetUsersByMapComponent(self.Entity.MapComponent)) do
			if e.uid == user.PlayerComponent.UserId then
				continue
			end
			self:AddMinimapUserMarker(e.uid, user.PlayerComponent.UserId)
		end
	end

	@ExecSpace("ServerOnly")
	@EventSender("Self")
	handler HandleMapLeaveEvent(MapLeaveEvent e)
		for _, user in ipairs(_UserService:GetUsersByMapComponent(self.Entity.MapComponent)) do
			if e.uid == user.PlayerComponent.UserId then
				continue
			end
			self:RemoveMinimapUserMarker(e.uid, user.PlayerComponent.UserId)
		end
	end

end