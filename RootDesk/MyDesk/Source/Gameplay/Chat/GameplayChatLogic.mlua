@Logic
script GameplayChatLogic extends Logic

	readonly property integer MaxGlobalChatCount = 25

	readonly property integer MaxMapChatCount = 50

	readonly property number MaxUserNameWidth = 600.0

	readonly property integer MaxUserMessageLength = 200

	---@description "전역 채팅 엔티티 리스트"
	property table globalChatEntities = {}

	---@description "맵별 채팅 엔티티 리스트"
	property table mapChatEntities = {}

	@ExecSpace("ServerOnly")
	method void OnBeginPlay()
		
	end

	---@description "유저 메세지를 보냅니다"
	@ExecSpace("Server")
	method void SendUserMessage(string uid, ChatEntity entity, number userNameWidth)
		if uid ~= senderUserId then
			return
		end

		if entity == nil or _UtilLogic:IsNilorEmptyString(entity.message) == true then
			return
		end

		local userEntity = _UserService.UserEntities[uid]
		if userEntity == nil then
			return
		end

		local userStorageCom = _UserProxy:GetUserStorageComponentByServer(uid)
		if userStorageCom == nil then
			return
		end

		local gameplayChar = userStorageCom:GetGameplayCharacter()
		if gameplayChar == nil then
			return
		end

		local normalizedUserNameWidth = self:NormalizeUserNameWidth(userNameWidth)
		local sanitizedMessage = self:SanitizeUserMessage(entity.message)
		if _UtilLogic:IsNilorEmptyString(sanitizedMessage) == true then
			return
		end

		-- entry 설정
		-- TODO: 로그 저장용인데 지금은 구현하지 않음... 로그를 구현한다면 그때 기능이 작동 되도록 수정
		-- entity.createTime = DateTime.UtcNow.Elapsed
		-- entity.chatType = _ChatTypeDef.User

		-- local userNameParam = ChatParamEntity()
		-- userNameParam.paramType = _ChatParamTypeDef.UserName
		-- userNameParam.paramValue = gameplayChar.name
		-- entity.params["UserName"] = userNameParam

		-- 채팅 레이아웃 설정
		local userLayout = ChatEntryLayout_User()
		userLayout.userName = gameplayChar.name
		userLayout.userNameWidth = normalizedUserNameWidth
		userLayout.msg = sanitizedMessage

		local layout = ChatEntryLayout()
		layout.chatType = _ChatTypeDef.User
		layout.params = userLayout:ToTable()
		
		-- 같은 맵에 있는 유저들에게만 전송
		local users = _UserService:GetUsersByMapName(userEntity.CurrentMapName)
		local e = ReceiveChatEvent()
		e.layout = layout

		for _, u in ipairs(users) do
			local userUid = u.PlayerComponent.UserId
			if userUid == uid then
				continue
			end
			_UserProxy:SendEventToLocalPlayer(e, userUid)
		end

		_UserProxy:SendEventToPlayer(e, uid)
	end

	@ExecSpace("ServerOnly")
	method number NormalizeUserNameWidth(number userNameWidth)
		if userNameWidth == nil then
			return 0
		end

		if userNameWidth ~= userNameWidth then
			return 0
		end

		if userNameWidth < 0 then
			return 0
		end

		if userNameWidth > self.MaxUserNameWidth then
			return self.MaxUserNameWidth
		end

		return userNameWidth
	end

	@ExecSpace("ServerOnly")
	method string SanitizeUserMessage(string message)
		if _UtilLogic:IsNilorEmptyString(message) == true then
			return ""
		end

		local sanitized = message
		local _ = 0
		sanitized, _ = string.gsub(sanitized, "<.->", "")
		sanitized, _ = string.gsub(sanitized, "[\r\n\t]", " ")

		local messageLength = utf8.len(sanitized)
		if messageLength == nil or messageLength <= 0 then
			return ""
		end

		if messageLength > self.MaxUserMessageLength then
			return ""
		end

		return sanitized
	end

end